generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model detil_kepengurusan {
  id_detil_kepengurusan Int           @id @default(autoincrement())
  kepengurusan_id       Int?          @default(0)
  kode_wilayah          String?       @db.VarChar(128)
  pribadi_id            Int?          @default(0)
  jabatan_id            Int?          @default(0)
  jabatan_pn            String?       @db.VarChar(256)
  is_active             Int?          @default(1) @db.TinyInt
  OldKodeWilayah        String?       @db.VarChar(50)
  IdWilayah             Int?
  created               DateTime?     @default(now()) @db.DateTime(0)
  updated               DateTime?     @db.DateTime(0)
  jabatan               jabatan?      @relation(fields: [jabatan_id], references: [id_jabatan], onDelete: NoAction, onUpdate: NoAction, map: "detil_jabatan_FK")
  kepengurusan          kepengurusan? @relation(fields: [kepengurusan_id], references: [id_kepengurusan], onDelete: NoAction, onUpdate: NoAction, map: "detil_kepengurusan_FK")
  pribadi               pribadi?      @relation(fields: [pribadi_id], references: [idpribadi], onDelete: NoAction, onUpdate: NoAction, map: "detil_pribadi_FK")

  @@index([jabatan_id], map: "detil_jabatan_FK")
  @@index([kepengurusan_id], map: "detil_kepengurusan_FK")
  @@index([pribadi_id], map: "detil_pribadi_FK")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model jabatan {
  id_jabatan         Int                  @id @default(autoincrement())
  nama               String?              @db.VarChar(512)
  json_jabatan       String?              @db.Text
  level_id           Int?
  created            DateTime?            @default(now()) @db.DateTime(0)
  updated            DateTime?            @db.DateTime(0)
  detil_kepengurusan detil_kepengurusan[]
  level              level?               @relation(fields: [level_id], references: [id_level], onDelete: NoAction, onUpdate: NoAction, map: "jabatan_level_FK")

  @@index([level_id], map: "jabatan_level_FK")
}

